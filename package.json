  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-html-parser": "^6.1.13",
    "pdf-lib": "^1.17.1"
  }

# 이 파일을 복사해서 ".env" 파일을 만들고 키를 채워주세요.
#   cp .env.example .env

# Claude(번역·구조화·증류)용 API 키 — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# (선택) 봇 차단 사이트 우회용 리더 프록시. 기본값은 Jina AI Reader.
#   직접 fetch가 막히면(403 등) 이 프록시를 통해 본문을 가져옵니다.
READER_PROXY=https://r.jina.ai/

# (선택) 서버 포트
PORT=3000
